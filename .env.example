# WarDesk Docker Compose defaults. Copy to .env and edit as needed.
POSTGRES_USER=wardesk
POSTGRES_PASSWORD=wardesk
POSTGRES_DB=wardesk
POSTGRES_PORT=5432

# Compose service DNS name is "db"; do not use localhost from inside containers.
DATABASE_URL=postgresql+asyncpg://wardesk:wardesk@db:5432/wardesk

BACKEND_PORT=8000
FRONTEND_PORT=5173
FRONTEND_PROD_PORT=8080
VITE_BACKEND_ORIGIN=http://backend:8000

WARDESK_CONTACT=you@example.com
INGEST_INTERVAL_SECONDS=45
RATE_LIMIT_GUARD=true
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Optional passthrough credentials; leave blank to disable related integrations.
ANTHROPIC_API_KEY=
STEAM_API_KEY=
